def reverse_string(string):
    return string[::-1]

def reverse_string_loop(string):
    reversed_string =""
    for char in string:
        reversed_string = char + reversed_string
    return reversed_string
    
print(reverse_string("hello")) # will output: olleh
print(reverse_string("Python")) # will output: nohtyP
print (reverse_string_loop("swathi"))